    "autoprefixer": "^10",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "postcss": "^8",
    "tailwindcss": "3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
